{
  "name": "hello-world",
  "version": "1.0.0",
  "description": "A simple example plugin that demonstrates the OpenChat plugin system",
  "author": "OpenChat",
  "tools": [
    {
      "name": "greet",
      "description": "Say hello to someone",
      "inputSchema": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "description": "Name of the person to greet"
          }
        },
        "required": ["name"]
      },
      "isReadOnly": true,
      "isDestructive": false
    }
  ]
}
